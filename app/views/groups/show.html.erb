<% my_net = (@me && @plan.nets[@me]).to_i %>
<div class="wt-page">
  <header class="flex items-center justify-between mb-4">
    <%= link_to "‹ もどる", root_path, class: "wt-back" %>
    <%= link_to "招待", invite_group_path(@group), class: "wt-pill" %>
  </header>

  <div class="flex items-center gap-3 mb-4">
    <span class="wt-tile" style="width:60px;height:60px;border-radius:18px;font-size:30px;background:<%= @group.tile %>;"><%= @group.icon %></span>
    <div class="min-w-0">
      <h1 class="wt-display truncate" style="font-size:1.4rem;font-weight:900;"><%= @group.name %></h1>
      <div class="wt-meta"><%= @members.reject { |m| m.name == "共同口座" }.size %>人のグループ</div>
    </div>
  </div>

  <%# 残高 %>
  <div class="wt-card text-center mb-4 <%= 'wt-fresh' if @fresh %>">
    <div class="wt-meta mb-1">あなたの残高</div>
    <div class="wt-hero-balance <%= balance_class(my_net) %>">
      <%= my_net.zero? ? "精算済み 🎉" : signed_yen(my_net) %>
    </div>
    <% unless my_net.zero? %>
      <div class="wt-meta mt-1"><%= my_net.positive? ? "受け取る予定" : "支払う予定" %></div>
    <% end %>
  </div>

  <%# 精算プラン %>
  <% if @plan.transfers.any? %>
    <div class="wt-card mb-4">
      <div class="flex items-baseline justify-between mb-1">
        <div class="wt-section-title" style="font-size:.95rem;">精算プラン</div>
        <div class="wt-meta" style="color:var(--accent);">最少 <%= @plan.transfers.size %> 回の送金</div>
      </div>
      <% @plan.transfers.each do |t| %>
        <div class="wt-plan-row">
          <%= member_avatar(t.from, size: 26) %>
          <span class="wt-plan-name"><%= t.from.name %></span>
          <span class="wt-meta">→</span>
          <%= member_avatar(t.to, size: 26) %>
          <span class="wt-plan-name"><%= t.to.name %></span>
          <span class="wt-plan-amount"><%= yen(t.amount) %></span>
        </div>
      <% end %>
      <div class="mt-3 flex gap-2 items-stretch">
        <%= link_to "LINEで共有", share_group_path(@group), class: "wt-btn wt-btn-line", style: "flex:1;" %>
        <span style="flex:1; display:flex;">
          <%= confirm_action_button("精算する", group_settlement_path(@group), method: :post,
                message: "この内容で精算を確定しますか？（記録は精算済みになります）",
                button_class: "wt-btn wt-btn-ghost", style: "flex:1;") %>
        </span>
      </div>
    </div>
  <% end %>

  <%# メンバー %>
  <div class="wt-section-head" style="margin-top:.5rem;"><div class="wt-section-title" style="font-size:.95rem;">メンバー</div></div>
  <div class="flex gap-3 overflow-x-auto pb-1">
    <% @members.each do |m| %>
      <div class="flex flex-col items-center gap-1" style="flex:none;width:54px;">
        <%= member_avatar(m, size: 40) %>
        <span class="wt-meta truncate" style="max-width:54px;"><%= m.name %><%= "（あなた）" if m.you?(current_user) %></span>
      </div>
    <% end %>
  </div>

  <%# 最近の記録 %>
  <div class="wt-section-head"><div class="wt-section-title" style="font-size:.95rem;">最近の記録</div></div>
  <% if @recent.empty? %>
    <p class="wt-meta">まだ記録がありません。</p>
  <% else %>
    <% @recent.each do |e| %>
      <div class="flex items-center gap-2.5 py-2" style="border-bottom:1px solid var(--line-soft);">
        <%= member_avatar(e.payer, size: 30) %>
        <div class="min-w-0 flex-1">
          <div class="truncate" style="font-size:.9rem;font-weight:700;"><%= e.title %></div>
          <div class="wt-meta"><%= e.payer.name %>が立替 · <%= e.expense_date.strftime("%-m/%-d") %></div>
        </div>
        <span style="font-weight:700;"><%= yen(e.amount) %></span>
        <%= confirm_action_button("🗑", group_expense_path(@group, e), method: :delete,
              message: "この記録を削除しますか？", button_class: "wt-pill wt-pill-mute", style: "padding:.3rem .5rem;") %>
      </div>
    <% end %>
  <% end %>

  <div class="mt-5">
    <%= link_to "＋ このグループで割り勘を追加", new_group_expense_path(@group), class: "wt-btn wt-btn-primary" %>
  </div>
</div>
