<div class="wt-page">
  <header class="flex items-center mb-4">
    <%= link_to "‹ もどる", group_path(@group), class: "wt-back" %>
  </header>

  <div class="flex items-center gap-3 mb-3">
    <span class="wt-tile" style="width:48px;height:48px;border-radius:14px;font-size:24px;background:<%= @group.tile %>;"><%= @group.icon %></span>
    <div>
      <h1 class="wt-display" style="font-size:1.2rem;font-weight:900;">精算を共有</h1>
      <div class="wt-meta"><%= @group.name %></div>
    </div>
  </div>

  <%# メッセージプレビュー %>
  <div class="wt-pre mb-4"><%= @text %></div>

  <%= link_to "LINEで送る", "https://line.me/R/share?text=#{CGI.escape(@text)}",
        target: "_blank", rel: "noopener", class: "wt-btn wt-btn-line mb-2" %>

  <div data-controller="copy-text">
    <textarea data-copy-text-target="source" class="hidden"><%= @text %></textarea>
    <button type="button" class="wt-btn wt-btn-ghost" data-action="copy-text#copy">テキストをコピー</button>
    <p class="wt-meta hidden mt-2 text-center" data-copy-text-target="feedback">コピーしました ✓</p>
  </div>
</div>
