<div class="wt-page" data-controller="expense-form">
  <header class="flex items-center justify-between mb-3">
    <%= link_to "‹ もどる", group_path(@group), class: "wt-back" %>
    <span class="wt-pill wt-pill-mute"><%= @group.icon %> <%= @group.name %></span>
  </header>

  <% if flash.now[:alert] %><div class="wt-alert-box"><%= flash.now[:alert] %></div><% end %>

  <%= form_with url: group_expenses_path(@group), method: :post, data: { turbo: false } do %>
    <%# 金額 %>
    <div class="wt-card text-center mb-3">
      <%= number_field_tag :amount, nil, inputmode: "numeric", class: "wt-amount-big", placeholder: "¥0",
            min: 1, data: { expense_form_target: "amount", action: "input->expense-form#recalc" } %>
      <div class="wt-meta" data-expense-form-target="perEach">参加者を選んでね</div>
    </div>

    <%# クイックタイトル %>
    <div class="wt-chips mb-3">
      <% Groups::ExpensesController::QUICK_TITLES.each do |t| %>
        <button type="button" class="wt-chip" data-expense-form-target="chip"
                data-action="expense-form#setTitle" data-expense-form-title-param="<%= t %>"><%= t %></button>
      <% end %>
    </div>

    <div class="mb-4">
      <%= label_tag :title, "タイトル", class: "wt-label" %>
      <%= text_field_tag :title, nil, class: "wt-input", placeholder: "例: 居酒屋", data: { expense_form_target: "title" } %>
    </div>

    <%# 立て替えた人 %>
    <div class="mb-4">
      <span class="wt-label">立て替えた人</span>
      <select name="payer_id" class="wt-input">
        <% @members.each do |m| %>
          <option value="<%= m.id %>" <%= "selected" if m == @payer %>><%= m.name %><%= "（あなた）" if m.you?(current_user) %></option>
        <% end %>
      </select>
    </div>

    <%# 割り方 %>
    <div class="mb-2 flex gap-2">
      <input type="hidden" name="split_mode" value="equal" data-expense-form-target="mode">
      <button type="button" class="wt-pill wt-pill-active" data-expense-form-target="modeBtn"
              data-action="expense-form#toggleMode" data-expense-form-mode-param="equal">均等に割る</button>
      <button type="button" class="wt-pill wt-pill-mute" data-expense-form-target="modeBtn"
              data-action="expense-form#toggleMode" data-expense-form-mode-param="custom">金額を指定</button>
    </div>

    <%# メンバーごとの負担 %>
    <div class="wt-card mb-5">
      <% @members.each do |m| %>
        <div class="wt-mrow" data-expense-form-target="row">
          <label class="flex items-center gap-2 flex-1 min-w-0">
            <%= check_box_tag "participant_ids[]", m.id, true, data: { expense_form_target: "check", action: "change->expense-form#recalc" } %>
            <%= member_avatar(m, size: 30) %>
            <span class="wt-mrow-name truncate"><%= m.name %><% if m.you?(current_user) %><span class="wt-you-tag">あなた</span><% end %></span>
          </label>
          <div class="flex items-center gap-1">
            <span class="wt-meta">¥</span>
            <%= number_field_tag "shares[#{m.id}]", 0, inputmode: "numeric", class: "wt-share-input", readonly: true,
                  data: { expense_form_target: "share", action: "input->expense-form#recalc" } %>
          </div>
        </div>
      <% end %>
    </div>

    <%= submit_tag "この内容で記録する", class: "wt-btn wt-btn-primary" %>
  <% end %>
</div>
