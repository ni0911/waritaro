<div class="wt-page-center">
  <div class="mb-8">
    <h1 class="wt-page-title text-xl">グループを作成する</h1>
    <p class="text-sm mt-1 wt-text-3">2人分の名前を入力してグループを作りましょう。</p>
  </div>

  <% if flash[:alert] %>
    <div class="wt-alert-box"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with model: @setting, url: create_group_setting_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <label class="wt-label">メンバーA の名前（自分）</label>
      <%= f.text_field :member_a,
            class: "wt-input",
            placeholder: "たろう" %>
      <% if @setting.errors[:member_a].any? %>
        <p class="wt-error"><%= @setting.errors[:member_a].first %></p>
      <% end %>
    </div>

    <div>
      <label class="wt-label">メンバーB の名前（パートナー）</label>
      <%= f.text_field :member_b,
            class: "wt-input",
            placeholder: "はなこ" %>
      <% if @setting.errors[:member_b].any? %>
        <p class="wt-error"><%= @setting.errors[:member_b].first %></p>
      <% end %>
    </div>

    <%= f.submit "グループを作成する", class: "wt-btn wt-btn-primary mt-2" %>
  <% end %>

  <div class="mt-8 text-center">
    <p class="text-sm wt-text-3">招待コードをお持ちの方は</p>
    <%= link_to "招待コードで参加する", join_setting_path, class: "wt-link text-sm" %>
  </div>
</div>
