<div class="wt-page-center">
  <div class="mb-8">
    <h1 class="wt-page-title text-xl">招待コードで参加する</h1>
    <p class="text-sm mt-1 wt-text-3">パートナーから受け取った招待コードを入力してください。</p>
  </div>

  <% if @error %>
    <div class="wt-alert-box"><%= @error %></div>
  <% end %>

  <%= form_with url: join_setting_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <label class="wt-label">招待コード</label>
      <%= f.text_field :invite_code,
            class: "wt-input wt-input-mono",
            placeholder: "招待コードを貼り付けてください",
            autocomplete: "off" %>
    </div>

    <%= f.submit "参加する", class: "wt-btn wt-btn-primary mt-2" %>
  <% end %>

  <div class="mt-8 text-center">
    <p class="text-sm wt-text-3">新しいグループを作成する場合は</p>
    <%= link_to "グループを作成する", new_group_setting_path, class: "wt-link text-sm" %>
  </div>
</div>
