<div class="px-4 py-6 max-w-md mx-auto">
  <h1 class="text-lg font-bold mb-2">招待コードで参加する</h1>
  <p class="text-sm text-gray-500 mb-6">パートナーから受け取った招待コードを入力してください。</p>

  <% if @error %>
    <p class="py-2 px-3 bg-red-50 mb-4 text-red-500 font-medium rounded-lg"><%= @error %></p>
  <% end %>

  <%= form_with url: join_setting_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">招待コード</label>
      <%= f.text_field :invite_code,
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-base bg-gray-50 font-mono",
            placeholder: "招待コードを貼り付けてください",
            autocomplete: "off" %>
    </div>

    <%= f.submit "参加する",
          class: "w-full bg-green-500 text-white py-3.5 rounded-xl text-base font-semibold mt-2" %>
  <% end %>

  <div class="mt-6 text-center">
    <p class="text-sm text-gray-500">新しいグループを作成する場合は</p>
    <%= link_to "グループを作成する", new_group_setting_path, class: "text-blue-500 underline text-sm" %>
  </div>
</div>
