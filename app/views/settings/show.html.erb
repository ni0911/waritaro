<div class="wt-page">
  <h1 class="wt-page-title mb-5">設定</h1>

  <%# 招待コード %>
  <% if @setting.invite_code %>
    <div class="wt-invite-box mb-5">
      <p class="wt-label-xs mb-2">招待コード（パートナーに共有）</p>
      <p class="wt-invite-code"><%= @setting.invite_code %></p>
    </div>
  <% end %>

  <%= form_with model: @setting, url: setting_path, method: :patch, class: "space-y-4" do |f| %>
    <div>
      <label class="wt-label">メンバーA の名前</label>
      <%= f.text_field :member_a,
            class: "wt-input",
            placeholder: "たろう" %>
      <% if @setting.errors[:member_a].any? %>
        <p class="wt-error"><%= @setting.errors[:member_a].first %></p>
      <% end %>
    </div>

    <div>
      <label class="wt-label">メンバーB の名前</label>
      <%= f.text_field :member_b,
            class: "wt-input",
            placeholder: "はなこ" %>
      <% if @setting.errors[:member_b].any? %>
        <p class="wt-error"><%= @setting.errors[:member_b].first %></p>
      <% end %>
    </div>

    <%= f.submit "保存する", class: "wt-btn wt-btn-primary mt-2" %>
  <% end %>

  <div class="mt-8 pt-6 wt-border-top">
    <%= button_to "ログアウト", session_path, method: :delete,
          class: "wt-btn wt-btn-ghost" %>
  </div>
</div>
