<div class="wt-page-center">
  <div class="mb-8 text-center">
    <span class="wt-auth-brand">ワリタロ</span>
    <p class="wt-auth-tagline mt-1">アカウントを作成する</p>
  </div>

  <% if flash[:alert] %>
    <div class="wt-alert-box"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with model: @user, url: registrations_path, class: "space-y-4" do |f| %>
    <div>
      <label class="wt-label">メールアドレス</label>
      <%= f.email_field :email_address,
            class: "wt-input",
            placeholder: "example@email.com",
            autocomplete: "username" %>
      <% if @user.errors[:email_address].any? %>
        <p class="wt-error"><%= @user.errors[:email_address].first %></p>
      <% end %>
    </div>

    <div>
      <label class="wt-label">パスワード</label>
      <%= f.password_field :password,
            class: "wt-input",
            autocomplete: "new-password" %>
      <% if @user.errors[:password].any? %>
        <p class="wt-error"><%= @user.errors[:password].first %></p>
      <% end %>
    </div>

    <div>
      <label class="wt-label">パスワード（確認）</label>
      <%= f.password_field :password_confirmation,
            class: "wt-input",
            autocomplete: "new-password" %>
    </div>

    <%= f.submit "アカウントを作成する", class: "wt-btn wt-btn-primary mt-2" %>
  <% end %>

  <p class="mt-6 text-center text-sm wt-text-3">
    すでにアカウントをお持ちの方は
    <%= link_to "ログイン", new_session_path, class: "wt-link" %>
  </p>
</div>
