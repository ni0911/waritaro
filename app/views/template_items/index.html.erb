<div class="wt-page">
  <div class="wt-page-header">
    <h1 class="wt-page-title">固定費テンプレート</h1>
    <%= link_to "＋ 追加", new_template_item_path,
          class: "wt-btn wt-btn-primary wt-btn-sm" %>
  </div>

  <% if @template_items.empty? %>
    <div class="wt-empty">
      <span class="wt-empty-icon">📝</span>
      <p class="wt-empty-text">テンプレートが登録されていません</p>
      <p class="wt-empty-hint">毎月の固定費を登録しておくと便利です</p>
    </div>
  <% else %>
    <div id="template_items_list" class="space-y-2">
      <% @template_items.each do |item| %>
        <%= render "template_item", template_item: item %>
      <% end %>
    </div>
  <% end %>
</div>
