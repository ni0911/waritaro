<%= form_with model: template_item, class: "space-y-4" do |f| %>
  <div>
    <label class="wt-label">費目名</label>
    <%= f.text_field :name,
          class: "wt-input",
          placeholder: "家賃" %>
    <% if template_item.errors[:name].any? %>
      <p class="wt-error"><%= template_item.errors[:name].first %></p>
    <% end %>
  </div>

  <div data-controller="burden-auto-calc">
    <label class="wt-label">金額（円）</label>
    <%= f.number_field :amount,
          class: "wt-input",
          min: 0, placeholder: "120000",
          data: { burden_auto_calc_target: "amount", action: "input->burden-auto-calc#calcBurdenB" } %>

    <label class="wt-label mb-2 mt-4">負担額</label>
    <div class="flex gap-3">
      <div class="flex-1">
        <label class="wt-label-xs"><%= @setting.member_a %></label>
        <%= f.number_field :burden_a,
              class: "wt-input mt-1",
              min: 0, placeholder: "0",
              data: { burden_auto_calc_target: "burdenA", action: "input->burden-auto-calc#calcBurdenB" } %>
      </div>
      <div class="flex-1">
        <label class="wt-label-xs"><%= @setting.member_b %></label>
        <%= f.number_field :burden_b,
              class: "wt-input mt-1",
              min: 0, placeholder: "0",
              data: { burden_auto_calc_target: "burdenB", action: "input->burden-auto-calc#calcBurdenA" } %>
      </div>
    </div>
    <p class="text-xs mt-1.5" style="color: var(--text-3);">
      金額か片方の負担額を入力すると、もう片方が自動計算されます
    </p>
    <% if template_item.errors[:base].any? %>
      <% template_item.errors[:base].each do |msg| %>
        <p class="wt-error"><%= msg %></p>
      <% end %>
    <% end %>
  </div>

  <div>
    <label class="wt-label">カード（任意）</label>
    <%= f.collection_select :card_id, cards, :id, :name,
          { include_blank: "現金" },
          class: "wt-input" %>
  </div>

  <%= f.submit template_item.new_record? ? "追加する" : "保存する",
        class: "wt-btn wt-btn-primary mt-2" %>
<% end %>
