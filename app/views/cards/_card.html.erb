<div id="card_<%= card.id %>"
     class="wt-card-flat px-4 py-3 flex items-center justify-between">
  <p class="text-sm font-medium wt-text-1">💳 <%= card.name %></p>
  <div class="flex gap-3">
    <%= link_to "編集", edit_card_path(card),
          class: "text-sm font-medium py-2 px-1 wt-text-gold" %>
    <%= button_to "削除",
          card_path(card),
          method: :delete,
          form: { id: "delete_card_#{card.id}" },
          class: "hidden" %>
    <button type="button"
            data-action="confirm-modal#open"
            data-confirm-modal-message-param="「<%= card.name %>」を削除しますか？"
            data-confirm-modal-form-param="delete_card_<%= card.id %>"
            class="text-sm font-medium py-2 px-1 wt-text-danger">
      削除
    </button>
  </div>
</div>
