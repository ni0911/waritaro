<div class="wt-page">
  <div class="wt-page-header">
    <h1 class="wt-page-title">カード管理</h1>
    <%= link_to "＋ 追加", new_card_path,
          class: "wt-btn wt-btn-primary wt-btn-sm" %>
  </div>

  <% [["A", @setting.member_a, @cards_a], ["B", @setting.member_b, @cards_b]].each do |owner, name, cards| %>
    <div class="mb-6">
      <p class="wt-section-label"><%= name %>のカード</p>
      <% if cards.empty? %>
        <p class="text-sm py-3" style="color: var(--text-3);">登録なし</p>
      <% else %>
        <div class="space-y-2">
          <% cards.each do |card| %>
            <%= render "card", card: card %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
