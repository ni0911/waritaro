<div class="px-4 py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-lg font-bold">カード管理</h1>
    <%= link_to "＋ 追加", new_card_path,
          class: "bg-blue-500 text-white text-sm px-4 py-2 rounded-xl font-medium" %>
  </div>

  <% [["A", @setting.member_a, @cards_a], ["B", @setting.member_b, @cards_b]].each do |owner, name, cards| %>
    <div class="mb-6">
      <h2 class="text-sm font-semibold text-gray-500 mb-2"><%= name %>のカード</h2>
      <% if cards.empty? %>
        <p class="text-gray-400 text-sm py-3">登録なし</p>
      <% else %>
        <div class="space-y-3">
          <% cards.each do |card| %>
            <%= render "card", card: card %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
