<%= form_with model: card, class: "space-y-4" do |f| %>
  <div>
    <label class="wt-label">カード名</label>
    <%= f.text_field :name,
          class: "wt-input",
          placeholder: "楽天カード" %>
    <% if card.errors[:name].any? %>
      <p class="wt-error"><%= card.errors[:name].first %></p>
    <% end %>
  </div>

  <div>
    <label class="wt-label mb-2">持ち主</label>
    <div class="flex gap-2">
      <% [["A", @setting.member_a], ["B", @setting.member_b]].each do |value, label| %>
        <label class="flex-1 flex items-center justify-center gap-2 rounded-xl py-2.5 cursor-pointer transition-all"
               style="border: 1.5px solid var(--border-md); color: var(--text-3);">
          <%= f.radio_button :owner, value, class: "sr-only" %>
          <%= label %>
        </label>
      <% end %>
    </div>
    <% if card.errors[:owner].any? %>
      <p class="wt-error"><%= card.errors[:owner].first %></p>
    <% end %>
  </div>

  <%= f.submit card.new_record? ? "追加する" : "保存する",
        class: "wt-btn wt-btn-primary mt-2" %>
<% end %>
