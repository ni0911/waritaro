<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>ワリタロ会計部</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&family=Shippori+Mincho+B1:wght@400;600&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="confirm-modal prompt-modal">
    <div class="mx-auto max-w-md min-h-screen flex flex-col">

      <%# フラッシュメッセージ %>
      <% if notice %>
        <div class="wt-flash-notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="wt-flash-alert"><%= alert %></div>
      <% end %>

      <%# メインコンテンツ %>
      <main class="flex-1 pb-20">
        <%= yield %>
      </main>

      <%# ボトムナビ %>
      <nav class="wt-nav">
        <div class="wt-nav-inner">
          <%= nav_tab "シート",   root_path,           icon: "📋" %>
          <%= nav_tab "テンプレ", template_items_path, icon: "📝" %>
          <%= nav_tab "カード",   cards_path,          icon: "💳" %>
          <%= nav_tab "設定",     setting_path,        icon: "⚙️" %>
        </div>
      </nav>

    </div>

    <%# 削除確認モーダル %>
    <%= render "shared/confirm_modal" %>

    <%# 年月入力モーダル %>
    <%= render "shared/prompt_modal" %>
  </body>
</html>
