<%# 年月入力モーダル — prompt_modal Stimulus コントローラーで制御 %>
<div data-prompt-modal-target="backdrop"
     class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center"
     id="prompt-modal">
  <div class="bg-white rounded-2xl shadow-xl mx-4 w-full max-w-sm p-6">
    <p class="text-base font-medium text-gray-800 mb-4">年月を入力してください</p>
    <input type="month"
           data-prompt-modal-target="input"
           class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-base mb-6"
           placeholder="2026-03">
    <div class="flex gap-3">
      <button type="button"
              data-action="prompt-modal#cancel"
              class="flex-1 py-2.5 rounded-xl border border-gray-300 text-gray-700 text-base font-medium">
        キャンセル
      </button>
      <button type="button"
              data-action="prompt-modal#confirm"
              class="flex-1 py-2.5 rounded-xl bg-blue-500 text-white text-base font-medium">
        作成
      </button>
    </div>
  </div>
</div>
