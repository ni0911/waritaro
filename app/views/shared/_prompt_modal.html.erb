<%# 年月入力モーダル — prompt_modal Stimulus コントローラーで制御 %>
<div data-prompt-modal-target="backdrop"
     class="hidden wt-modal-backdrop"
     id="prompt-modal">
  <div class="wt-modal-inner">
    <div class="wt-modal-card">
      <p class="wt-modal-title">年月を入力してください</p>
      <input type="text"
             inputmode="numeric"
             data-prompt-modal-target="input"
             class="wt-input mb-4"
             placeholder="2026-03"
             pattern="\d{4}-\d{2}">
      <div class="flex gap-2">
        <button type="button"
                data-action="prompt-modal#cancel"
                class="wt-btn wt-btn-ghost flex-1 py-2.5 text-sm">
          キャンセル
        </button>
        <button type="button"
                data-action="prompt-modal#confirm"
                class="wt-btn wt-btn-primary flex-1 py-2.5 text-sm">
          作成
        </button>
      </div>
    </div>
  </div>
</div>
