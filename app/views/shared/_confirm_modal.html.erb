<%# 削除確認モーダル — confirm_modal Stimulus コントローラーで制御 %>
<div data-confirm-modal-target="backdrop"
     class="hidden wt-modal-backdrop"
     id="confirm-modal">
  <div class="wt-modal-inner">
    <div class="wt-modal-card">
      <p class="wt-modal-title"
         data-confirm-modal-target="message">本当に削除しますか？</p>
      <div class="flex gap-2">
        <button type="button"
                data-action="confirm-modal#cancel"
                class="wt-btn wt-btn-ghost flex-1 py-2.5 text-sm">
          キャンセル
        </button>
        <button type="button"
                data-action="confirm-modal#confirm"
                data-confirm-modal-target="confirmBtn"
                class="wt-btn wt-btn-danger flex-1 py-2.5 text-sm">
          削除
        </button>
      </div>
    </div>
  </div>
</div>
