<%# 削除確認モーダル — confirm_modal Stimulus コントローラーで制御 %>
<div data-confirm-modal-target="backdrop"
     class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center"
     id="confirm-modal">
  <div class="bg-white rounded-2xl shadow-xl mx-4 w-full max-w-sm p-6">
    <p class="text-base font-medium text-gray-800 mb-6"
       data-confirm-modal-target="message">本当に削除しますか？</p>
    <div class="flex gap-3">
      <button type="button"
              data-action="confirm-modal#cancel"
              class="flex-1 py-2.5 rounded-xl border border-gray-300 text-gray-700 text-base font-medium">
        キャンセル
      </button>
      <button type="button"
              data-action="confirm-modal#confirm"
              data-confirm-modal-target="confirmBtn"
              class="flex-1 py-2.5 rounded-xl bg-red-500 text-white text-base font-medium">
        削除
      </button>
    </div>
  </div>
</div>
