<div class="wt-page">
  <div class="wt-page-header">
    <h1 class="wt-page-title">月次シート</h1>
    <button type="button"
            data-action="prompt-modal#open"
            data-prompt-modal-url-param="<%= sheets_path %>"
            data-prompt-modal-default-param="<%= Date.today.strftime('%Y-%m') %>"
            class="wt-btn wt-btn-primary wt-btn-sm">
      ＋ 新しい月
    </button>
  </div>

  <% if @sheets.empty? %>
    <div class="wt-empty">
      <span class="wt-empty-icon">📋</span>
      <p class="wt-empty-text">シートがありません</p>
      <p class="wt-empty-hint">「＋ 新しい月」から作成してください</p>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @sheets.each do |sheet| %>
        <div class="wt-sheet-row">
          <div>
            <%= link_to sheet.label, settlement_sheet_path(sheet.year_month),
                  class: "wt-sheet-label" %>
            <p class="wt-sheet-meta"><%= sheet.sheet_items.count %>件の費用</p>
          </div>
          <div class="flex items-center gap-3">
            <%= link_to "開く", settlement_sheet_path(sheet.year_month),
                  class: "text-sm font-medium wt-text-gold" %>
            <%= button_to "削除",
                  sheet_path(sheet.year_month),
                  method: :delete,
                  form: { id: "delete_sheet_#{sheet.id}" },
                  class: "hidden" %>
            <button type="button"
                    data-action="confirm-modal#open"
                    data-confirm-modal-message-param="<%= sheet.label %>を削除しますか？"
                    data-confirm-modal-form-param="delete_sheet_<%= sheet.id %>"
                    class="text-sm font-medium wt-text-danger">
              削除
            </button>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
