<% @cards_by_id = @cards %>

<div class="wt-page">
  <%# ヘッダー %>
  <div class="wt-page-header">
    <%= link_to "← 戻る", root_path, class: "wt-back-btn" %>
    <h1 class="wt-page-title"><%= @sheet.label %></h1>
    <div></div>
  </div>

  <%# 費用追加フォーム %>
  <%= turbo_frame_tag "new_sheet_item" do %>
    <%= render "sheet_items/form", sheet: @sheet %>
  <% end %>

  <%# 費用リスト %>
  <div class="mt-4 space-y-2" id="sheet_items_list">
    <% @sheet_items.each do |item| %>
      <%= render "sheet_items/sheet_item", sheet_item: item, sheet: @sheet %>
    <% end %>
  </div>

  <%# テンプレート適用 %>
  <% if current_setting.template_items.any? %>
    <div class="mt-4">
      <%= button_to "テンプレートを適用",
            apply_template_sheet_path(@sheet.year_month),
            method: :post,
            data: { turbo_submits_with: "適用中…" },
            class: "wt-btn wt-btn-ghost text-sm py-2.5" %>
    </div>
  <% end %>

  <%# 精算結果 %>
  <div class="wt-card mt-6">
    <h2 class="text-sm font-bold mb-3" style="color: var(--text-2);">精算結果</h2>

    <% member_a = @setting.member_a %>
    <% member_b = @setting.member_b %>

    <div class="flex justify-between items-center text-sm">
      <span style="color: var(--text-2);">合計精算対象</span>
      <span class="font-semibold" style="color: var(--text-1);">
        <%= number_to_currency(@result.total_shared_amount, unit: "¥", precision: 0) %>
      </span>
    </div>

    <hr class="wt-divider">

    <div class="space-y-2">
      <% [[@result.deposit_a, member_a], [@result.deposit_b, member_b]].each do |deposit, name| %>
        <div class="wt-transfer-row">
          <span class="wt-transfer-name"><%= name %></span>
          <% if deposit > 0 %>
            <span class="wt-transfer-amount">
              → 共有口座 <%= number_to_currency(deposit, unit: "¥", precision: 0) %>
            </span>
          <% else %>
            <span class="wt-transfer-none">精算なし</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# 費目別内訳 %>
  <% if @sheet_items.any? %>
    <div class="wt-card mt-3">
      <h2 class="text-sm font-bold mb-3" style="color: var(--text-2);">費目別内訳</h2>
      <div class="space-y-1.5 text-sm">
        <% @sheet_items.each do |item| %>
          <div class="flex justify-between">
            <span class="truncate flex-1 mr-2" style="color: var(--text-2);"><%= item.name %></span>
            <span class="shrink-0" style="color: var(--text-1);">
              <%= number_to_currency(item.amount, unit: "¥", precision: 0) %>
            </span>
          </div>
        <% end %>
        <hr class="wt-divider">
        <div class="flex justify-between font-semibold">
          <span style="color: var(--text-2);">合計</span>
          <span style="color: var(--text-1);">
            <%= number_to_currency(@sheet_items.sum(&:amount), unit: "¥", precision: 0) %>
          </span>
        </div>
      </div>
    </div>
  <% end %>

  <%# LINE共有 %>
  <div class="mt-4" data-controller="copy-text">
    <textarea data-copy-text-target="source" class="hidden" readonly><%= @share_text %></textarea>
    <button data-action="copy-text#copy"
            class="wt-btn wt-btn-success">
      📋 LINE 共有テキストをコピー
    </button>
    <p data-copy-text-target="feedback"
       class="text-center text-sm mt-2 hidden"
       style="color: var(--success);">
      コピーしました！
    </p>
  </div>
</div>
