<%= turbo_frame_tag "sheet_item_#{sheet_item.id}" do %>
  <%= form_with model: [ sheet, sheet_item ],
                url: sheet_sheet_item_path(sheet.year_month, sheet_item),
                method: :patch,
                class: "wt-card wt-form-active space-y-3" do |f| %>
    <div data-controller="burden-selector"
         data-burden-selector-amount-value="<%= sheet_item.amount.to_i %>"
         data-burden-selector-mode-value="custom">
      <div class="flex gap-2">
        <%= f.text_field :name,
              class: "wt-input",
              style: "flex: 1; min-width: 0;",
              placeholder: "費目名" %>
        <%= f.number_field :amount,
              data: { action: "input->burden-selector#updateAmount" },
              class: "wt-input",
              style: "width: 7rem; flex-shrink: 0;",
              min: 0 %>
      </div>

      <div class="flex gap-2 items-center">
        <span class="text-sm shrink-0 wt-text-2">支払い方法:</span>
        <%= f.collection_select :card_id, current_setting.cards.order(:owner, :name), :id, :name,
              { include_blank: "現金" },
              class: "wt-input flex-1" %>
      </div>

      <%# 分担モード %>
      <div class="flex gap-2">
        <button type="button"
                data-action="burden-selector#setSplit"
                data-burden-selector-target="splitBtn"
                class="wt-mode-btn">
          割り勘
        </button>
        <button type="button"
                data-action="burden-selector#setCustom"
                data-burden-selector-target="customBtn"
                class="wt-mode-btn wt-mode-btn--active">
          固定額
        </button>
      </div>

      <div data-burden-selector-target="customFields" class="hidden gap-2 mt-0">
        <div class="flex-1">
          <label class="wt-label-xs"><%= @setting.member_a %>負担</label>
          <%= f.number_field :burden_a,
                data: { "burden-selector-target": "burdenA" },
                class: "wt-input mt-1",
                min: 0 %>
        </div>
        <div class="flex-1">
          <label class="wt-label-xs"><%= @setting.member_b %>負担</label>
          <%= f.number_field :burden_b,
                data: { "burden-selector-target": "burdenB" },
                class: "wt-input mt-1",
                min: 0 %>
        </div>
      </div>

      <%# 隠しフィールド %>
      <%= f.hidden_field :burden_a, data: { "burden-selector-target": "hiddenA" }, value: sheet_item.burden_a %>
      <%= f.hidden_field :burden_b, data: { "burden-selector-target": "hiddenB" }, value: sheet_item.burden_b %>

      <div class="flex gap-2">
        <%= f.submit "保存", class: "wt-btn wt-btn-primary flex-1 py-2.5 text-sm" %>
        <%= link_to "キャンセル",
              cancel_sheet_sheet_item_path(sheet.year_month, sheet_item),
              data: { turbo_method: :get, turbo_stream: true },
              class: "wt-btn wt-btn-ghost flex-1 py-2.5 text-sm" %>
      </div>
    </div>
  <% end %>
<% end %>
